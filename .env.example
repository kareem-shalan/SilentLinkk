# Local dev uses http://silentlink.runasp.net directly (no .env required).

# Do NOT set VITE_API_URL=http://... on Vercel — browsers block HTTP from HTTPS pages.
# Production uses same-origin /api, proxied to the backend via vercel.json.

# Only set this on Vercel if your backend supports HTTPS:
# VITE_API_URL=https://silentlink.runasp.net
