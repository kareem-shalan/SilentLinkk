# Optional — only for local dev when bypassing the Vite /api proxy.
# Do NOT set VITE_API_BASE_URL on Vercel (production uses /api serverless proxy).
# VITE_API_BASE_URL=http://silentlink.runasp.net

# Optional — override backend origin for the Vercel API proxy (server-side only).
# API_ORIGIN=http://silentlink.runasp.net
